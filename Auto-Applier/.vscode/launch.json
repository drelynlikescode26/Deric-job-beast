{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Run Auto-Applier",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--scout-now"],
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Python: Start Telegram Bot",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/telegram_bot.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Python: Run Executor",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/executor.py",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}"
    }
  ]
}
